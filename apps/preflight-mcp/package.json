{
	"name": "preflight-mcp",
	"version": "0.3.0",
	"private": true,
	"bin": {
		"deploylint-mcp": "./dist/index.js",
		"preflight-mcp": "./dist/index.js"
	},
	"type": "module",
	"scripts": {
		"build": "tsc",
		"start": "node dist/index.js",
		"dev": "tsx src/index.ts",
		"check": "tsc --noEmit",
		"lint": "oxfmt --check . && oxlint -c ../../.oxlintrc.jsonc --max-warnings=0 .",
		"lint:oxlint": "oxlint -c ../../.oxlintrc.jsonc --max-warnings=0 .",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"verify": "npm run check && npm run lint && npm run test:coverage && npm run build"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.12.1",
		"@vibe/deploylint-shared": "file:../deploylint-shared",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^26.1.0",
		"@vitest/coverage-v8": "^4.1.9",
		"tsx": "^4.22.5",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	}
}
