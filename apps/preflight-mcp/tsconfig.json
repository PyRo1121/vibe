{
	"compilerOptions": {
		"target": "ES2023",
		"lib": ["ES2023"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"types": ["node"]
	},
	"include": ["src/**/*"],
	"exclude": ["src/**/*.test.ts"]
}
