{
	"name": "@vibe/deploylint-shared",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"main": "./index.js",
	"types": "./index.d.ts",
	"exports": {
		".": {
			"types": "./index.d.ts",
			"default": "./index.js"
		}
	},
	"scripts": {
		"check": "node --check index.js",
		"lint": "oxfmt --check . && oxlint -c ../../.oxlintrc.jsonc --max-warnings=0 .",
		"lint:oxlint": "oxlint -c ../../.oxlintrc.jsonc --max-warnings=0 .",
		"verify": "npm run lint && npm run check",
		"format": "oxfmt .",
		"format:check": "oxfmt --check ."
	}
}
