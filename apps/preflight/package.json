{
	"name": "preflight",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && node scripts/export-durable-objects.mjs",
		"preview": "npm run build && wrangler dev",
		"prepare": "svelte-kit sync",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:scripts": "tsc --noEmit -p tsconfig.scripts.json",
		"check:e2e": "tsc --noEmit -p tsconfig.e2e.json",
		"check:migrations": "node scripts/check-d1-migrations.mjs",
		"lint": "oxfmt --check . && oxlint -c ../../.oxlintrc.jsonc --max-warnings=0 .",
		"lint:oxlint": "oxlint -c ../../.oxlintrc.jsonc --max-warnings=0 .",
		"lint:type-aware": "oxlint -c ../../.oxlintrc.jsonc --type-aware -A typescript/no-unsafe-type-assertion .",
		"lint:type-aware:prod": "oxlint -c ../../.oxlintrc.jsonc --type-aware --deny typescript/no-unsafe-type-assertion --ignore-pattern \"**/*.test.ts\" --ignore-pattern \"**/*.spec.ts\" --ignore-pattern \"e2e/**\" --ignore-pattern \"scripts/**\" .",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:e2e:install": "playwright install chromium",
		"test:watch": "vitest",
		"quality:standards": "tsx src/lib/quality/standards.ts",
		"verify": "npm run quality:standards && npm run sync:gate-remote:check && npm run check && npm run check:scripts && npm run check:e2e && npm run check:migrations && npm run lint && npm run lint:type-aware && npm run lint:type-aware:prod && npm run test:coverage && npm run build",
		"verify:full": "npm run verify && npm run test:e2e",
		"cf-typegen": "wrangler types src/cloudflare-env.d.ts --include-runtime false",
		"setup:stripe": "powershell -ExecutionPolicy Bypass -File scripts/setup-stripe.ps1",
		"setup:stripe:live": "powershell -ExecutionPolicy Bypass -File scripts/setup-stripe-live.ps1",
		"setup:deploylint-store:live": "powershell -ExecutionPolicy Bypass -File scripts/setup-deploylint-store-live.ps1",
		"stripe": "powershell -ExecutionPolicy Bypass -File scripts/stripe-cli.ps1",
		"stripe:login": "powershell -ExecutionPolicy Bypass -File scripts/finish-stripe-login.ps1",
		"stripe:test-webhook": "powershell -ExecutionPolicy Bypass -File scripts/test-webhook.ps1",
		"gate": "tsx scripts/gate.ts",
		"gate:remote": "node scripts/gate-remote.mjs",
		"migrations:apply:remote": "wrangler d1 migrations apply preflight-auth --remote",
		"sync:gate-remote": "node scripts/sync-gate-remote.mjs",
		"sync:gate-remote:check": "node scripts/sync-gate-remote.mjs --check",
		"smoke:phase18": "node scripts/smoke-phase18.mjs",
		"smoke:phase19": "node scripts/smoke-phase19.mjs",
		"smoke:phase20": "node scripts/smoke-phase20.mjs",
		"smoke:phase23": "node scripts/smoke-phase23.mjs",
		"smoke:phase24": "node scripts/smoke-phase24.mjs",
		"smoke": "npm run smoke:phase18 && npm run smoke:phase19 && npm run smoke:phase20 && npm run smoke:phase23 && npm run smoke:phase24",
		"changelog:draft": "node scripts/changelog-draft.mjs",
		"changelog:release": "node scripts/changelog-release.mjs",
		"setup:plausible-goals": "node scripts/setup-plausible-goals.mjs",
		"setup:cloudflare-firewall": "node scripts/setup-cloudflare-firewall.mjs",
		"seo:indexnow": "tsx scripts/submit-indexnow.ts",
		"count:checks": "node scripts/count-checks.mjs",
		"deploy": "npm run sync:gate-remote && npm run check:migrations && npm run build && npm run migrations:apply:remote && wrangler deploy"
	},
	"dependencies": {
		"@vibe/deploylint-shared": "file:../deploylint-shared",
		"better-auth": "^1.6.23",
		"resend": "^6.17.1"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^5.20260713.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/vite": "^4.3.2",
		"@types/node": "^26.1.0",
		"@vitest/coverage-v8": "^4.1.9",
		"svelte": "^5.56.4",
		"svelte-check": "^4.4.6",
		"tailwindcss": "^4.3.2",
		"tsx": "^4.22.5",
		"typescript": "^6.0.3",
		"vite": "^8.1.3",
		"vitest": "^4.1.9",
		"wrangler": "^4.110.0"
	}
}
