{
	"$schema": "https://turbo.build/schema.json",
	"globalDependencies": [".oxlintrc.jsonc", ".oxfmtrc.jsonc"],
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".svelte-kit/**", "build/**", "dist/**"]
		},
		"check": {
			"outputs": []
		},
		"test": {
			"outputs": []
		},
		"verify": {
			"outputs": []
		},
		"lint": {
			"outputs": []
		},
		"format": {
			"outputs": []
		},
		"format:check": {
			"outputs": []
		},
		"dev": {
			"cache": false,
			"persistent": true
		},
		"deploy": {
			"dependsOn": ["build"],
			"cache": false
		}
	}
}
